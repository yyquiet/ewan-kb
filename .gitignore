# ── 用户构建产物（从 source/ 派生，进 git）────────────────────────────────
knowledgeBase/
graph/

# ── 用户原始数据快照（从外部拉取覆盖，不提交到开源仓库）───────────────────
source/

# ── 工具运行时产物（用户 KB 目录下的 _state/）──────────────────────────────
# 状态文件现在存放在 knowledgeBase/_state/ 和 graph/.cache/ 下

# ── 环境配置（含敏感信息）───────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── 构建者本地配置（不提交）─────────────────────────────────────────────────
project_config.json
tools/discover/segment_stopwords_extends.json
tools/fetch_repos/repos.json

# ── 测试（本地开发用，不提交）─────────────────────────────────────────────────
tests/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.venv/
venv/
.python-version

# ── 系统文件 ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.bak
