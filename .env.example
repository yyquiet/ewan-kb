# Ewan-kb environment configuration
# Copy to .env and fill in actual values
#
# 注意：项目级 LLM 凭证推荐使用 llm_config.json（见 examples/llm_config.example.json）
# 本文件适用于全局默认配置场景

# ── Knowledge Base ──────────────────────────────────────────────────────────
# Override the default KB directory (defaults to current working directory)
# EWANKB_DIR=/path/to/your/kb-project

# ── Claude API ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_api_key_here
# ANTHROPIC_BASE_URL=           # For proxies; leave blank for direct access

# ── Confluence (optional — for scrape_cf tool) ─────────────────────────────
# CONFLUENCE_BASE_URL=https://your-confluence.example.com
# CONFLUENCE_USER=your_username
# CONFLUENCE_PASSWORD=your_password

# ── Git (optional — for fetch_repos tool) ──────────────────────────────────
# GIT_USER=your_git_username
# GIT_PASSWORD=your_git_password

# ── Database (optional — for fetch_db_schema tool) ──────────────────────────
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
